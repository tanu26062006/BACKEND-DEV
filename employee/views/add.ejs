
<!DOCTYPE html>
<html>
    <head>
        <title>Add Employee</title>
        <link rel="stylesheet" href="/style.css">
    </head>
    <body>
        <div class="nav">
            <p>Employee Payroll</p>
        </div>
        <div class="container">
            <div class="card form-card">
                <h1>Add Employee</h1>
                <form class="employee-form" action="/employee/signup" method="post">
                    <div class="grid">
                        <div>
                            <label for="name">Name</label>
                            <input type="text" id="name" name="name" required />
                        </div>
                        <div>
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" required />
                        </div>
                        <div>
                            <label for="password">Password</label>
                            <input type="text" id="password" name="password" minlength="4" maxlength="6" required />
                        </div>
                        <div>
                            <label for="department">Department</label>
                            <input type="text" id="department" name="department" required />
                        </div>
                        <div>
                            <label for="basic_salary">Basic Salary</label>
                            <input type="number" id="basic_salary" name="basic_salary" required />
                        </div>
                    </div>
                    <div class="form-actions">
                        <div class="left">
                            <a href="/home" class="btn-secondary btn-cancel">Cancel</a>
                        </div>
                        <div class="right">
                            <button type="submit" class="btn-primary btn-success">Add</button>
                            <button type="reset" class="btn-secondary btn-danger">Reset</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </body>
</html>
